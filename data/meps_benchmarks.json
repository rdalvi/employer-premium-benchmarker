  "self_funded_components": {
    "_doc": "Self-funded employer cost = FI premium x (1 - state_premium_tax - insurer_margin_pct + bucket.stop_loss_pct). State premium tax and insurer profit/risk margin are eliminated under ERISA self-funding; stop-loss premium is added. Plan-design and claims components are assumed equivalent at the bucket-average level.",
    "insurer_margin_pct": 0.040
  },

